      "elapsedMs": 500, "expectedLinear": [128, 0, 128] },
    { "name": "fade end = colorB",
      "cue": { "effect": 1, "durationMs": 1000, "colorA": [255, 0, 0], "colorB": [0, 0, 255], "param1": 0, "param2": 0, "brightness": 255 },
      "elapsedMs": 1000, "expectedLinear": [0, 0, 255] },
    { "name": "breathe trough at phase 0",
      "cue": { "effect": 2, "durationMs": 4000, "colorA": [0, 255, 0], "colorB": [0, 0, 0], "param1": 100, "param2": 0, "brightness": 255 },
      "elapsedMs": 0, "expectedLinear": [0, 0, 0] },
    { "name": "breathe peak at half period",
